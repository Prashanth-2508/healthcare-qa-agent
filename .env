# ── LLM Provider ──────────────────────────────────────────────────────────────
# OPTION A (Active): Local Ollama — gemma3:1b is already downloaded
LLM_PROVIDER=ollama
LLM_MODEL=gemma3:1b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
OLLAMA_BASE_URL=http://localhost:11434

# OPTION B (Better quality): Switch to Groq free tier
# Sign up at https://console.groq.com → API Keys → Create Key (takes 2 min, free)
# Then uncomment these 3 lines and comment out the OPTION A lines above:
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-70b-versatile
# GROQ_API_KEY=your_groq_api_key_here

# OPTION C: Together AI (free trial credits)
# LLM_PROVIDER=together
# LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# TOGETHER_API_KEY=your_together_api_key_here

# ── NCBI / PubMed ─────────────────────────────────────────────────────────────
# Free signup: https://www.ncbi.nlm.nih.gov/account/
# Without key: 3 req/s. With key: 10 req/s.
NCBI_API_KEY=
NCBI_EMAIL=balaji.gv@tungstenautomation.com
PUBMED_MAX_RESULTS=3


# ── Guidelines RAG ────────────────────────────────────────────────────────────
GUIDELINES_PDF_DIR=./data/guidelines_pdfs
GUIDELINES_CHROMA_DIR=./data/chroma_guidelines
GUIDELINES_EMBED_MODEL=all-MiniLM-L6-v2
GUIDELINES_CHUNK_SIZE=400
GUIDELINES_CHUNK_OVERLAP=80
GUIDELINES_TOP_K=3
GUIDELINES_MIN_SIMILARITY=0.25

# ── ICD-10 / CPT code lookup ──────────────────────────────────────────────────
CMS_ICD10_CACHE_DIR=./data/cms
CPT_CSV_PATH=
CODE_FUZZY_THRESHOLD=55
CODE_MAX_RESULTS=10

# ── Agent settings ────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=5
AGENT_MAX_OBSERVE_ITERATIONS=2
AGENT_VERBOSE=true
AGENT_TRACE_DIR=./traces

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./healthcare_qa.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── Evaluation (LLM-as-judge) ─────────────────────────────────────────────────
# Optional — falls back to heuristic scoring if not set
ANTHROPIC_API_KEY=
EVAL_JUDGE_MODEL=claude-haiku-4-5-20251001
EVAL_PASS_THRESHOLD=3.5
EVAL_TRACE_DIR=logs/eval_traces

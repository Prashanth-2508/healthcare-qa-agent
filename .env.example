# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: ollama | together | groq | huggingface
LLM_PROVIDER=ollama

# Model name (provider-specific)
# Ollama:       llama3.1:70b | llama3.1:8b | mixtral:8x7b | medllama3:latest
# Together AI:  meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# Groq:         llama-3.1-70b-versatile
# HuggingFace:  meta-llama/Meta-Llama-3.1-70B-Instruct
LLM_MODEL=llama3.1:70b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Ollama base URL (if using local Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Together AI (if LLM_PROVIDER=together)
TOGETHER_API_KEY=

# Groq (if LLM_PROVIDER=groq)
GROQ_API_KEY=

# HuggingFace Inference API (if LLM_PROVIDER=huggingface)
HUGGINGFACEHUB_API_TOKEN=

# ── NCBI / PubMed ─────────────────────────────────────────────────────────────
# Register free at: https://www.ncbi.nlm.nih.gov/account/
# Without API key: 3 req/s limit. With key: 10 req/s.
NCBI_API_KEY=
NCBI_EMAIL=your@email.com
PUBMED_MAX_RESULTS=5

# ── Guidelines RAG (sentence-transformers + ChromaDB) ─────────────────────────
# Directory containing clinical guideline PDF files to index
GUIDELINES_PDF_DIR=./data/guidelines_pdfs

# Directory where ChromaDB persists the vector index
GUIDELINES_CHROMA_DIR=./data/chroma_guidelines

# Sentence-transformers model for dense embeddings
# Options: all-MiniLM-L6-v2 (fast, 384-dim), all-mpnet-base-v2 (768-dim, slower)
# For medical domain: pritamdeka/S-PubMedBert-MS-MARCO (requires HF download)
GUIDELINES_EMBED_MODEL=all-MiniLM-L6-v2

# Sliding-window chunk size and overlap (in words)
GUIDELINES_CHUNK_SIZE=400
GUIDELINES_CHUNK_OVERLAP=80

# Number of chunks to retrieve per query
GUIDELINES_TOP_K=3

# Minimum cosine similarity score (0.0–1.0) to surface a chunk
GUIDELINES_MIN_SIMILARITY=0.25

# ── ICD-10 / CPT code lookup ──────────────────────────────────────────────────
# Cache directory for the downloaded CMS ICD-10-CM file (~4 MB)
CMS_ICD10_CACHE_DIR=./data/cms

# Optional: path to a local CPT CSV with columns 'code','description'
# CPT® codes require an AMA license — leave blank to use the CPT notice.
CPT_CSV_PATH=

# rapidfuzz WRatio threshold (0–100). Lower = more permissive matching.
CODE_FUZZY_THRESHOLD=55

# Default max results returned by lookup_medical_code
CODE_MAX_RESULTS=10

# ── Agent settings ────────────────────────────────────────────────────────────
# Hard cap on total act-node invocations across the whole run
AGENT_MAX_ITERATIONS=5

# Self-reflection loop cap: observe → plan → act cycles (default 3)
# Each iteration calls the LLM twice (act tools + observe reflection)
AGENT_MAX_OBSERVE_ITERATIONS=3

# Print the reasoning trace summary to stdout at end of each run
AGENT_VERBOSE=true

# Directory for JSONL reasoning trace files (one file per session_id)
AGENT_TRACE_DIR=./traces

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./healthcare_qa.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
